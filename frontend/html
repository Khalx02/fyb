
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CocoaSense – AI Cocoa Plant Analyser</title>

  <!-- Google Fonts -->
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- Application Styles -->
  <link rel="stylesheet" href="styles.css" />
</head>
<body>

<!-- ════════════════════════════════════════════════
     HEADER
     ════════════════════════════════════════════════ -->
<header>
  <div class="logo-pod">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="12" cy="13" rx="7" ry="9" />
      <path
        d="M12 4 Q14 1 17 2"
        stroke="#C9812E"
        stroke-width="1.5"
        fill="none"
        stroke-linecap="round"
      />
    </svg>
  </div>
  <div>
    <h1>CocoaSense</h1>
    <p>AI-Powered Cocoa Pod Analysis</p>
  </div>
</header>

<!-- ════════════════════════════════════════════════
     MAIN CONTENT
     ════════════════════════════════════════════════ -->
<main>

  <!-- ── TEXT OBSERVATION ── -->
  <div class="card">
    <div class="card-header">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      Describe What You Observe
    </div>
    <div class="card-body">
      <p class="input-label">Your Observation (text)</p>
      <textarea
        id="textInput"
        placeholder="E.g. The pod skin has turned yellow-orange, the surface has some dark patches, the leaves around it look healthy and green. The pod sounds hollow when tapped..."
      ></textarea>
    </div>
  </div>

  <!-- ── VOICE OBSERVATION ── -->
  <div class="card">
    <div class="card-header">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
        <path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8"/>
      </svg>
      Voice Observation
    </div>
    <div class="card-body">
      <p class="input-label">Record or Upload Audio</p>
      <div class="record-row">

        <!-- Microphone record toggle -->
        <button class="btn-record" id="recordBtn" type="button">
          <span class="rec-dot"></span>
          <span id="recordLabel">Record Voice</span>
        </button>

        <!-- Live recording timer -->
        <span class="rec-timer" id="recTimer"></span>

        <!-- Upload existing audio file -->
        <label class="upload-audio-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          Upload audio file
          <input type="file" id="audioFile" accept="audio/*" style="display:none" />
        </label>

      </div>
      <!-- Audio file name / recording status -->
      <div id="audioStatus"></div>
    </div>
  </div>

  <!-- ── IMAGE UPLOAD ── -->
  <div class="card">
    <div class="card-header">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <polyline points="21 15 16 10 5 21"/>
      </svg>
      Upload Plant Images
    </div>
    <div class="card-body">
      <p class="input-label">Photos (leaves, pods, seeds, plant)</p>

      <div class="drop-row">

        <!-- Leaves -->
        <div class="drop-zone" id="leafZone">
          <input type="file" id="leafFiles" accept="image/*" multiple />
          <div class="dz-icon">🍃</div>
          <div class="dz-label">Leaves</div>
          <div class="dz-sub">Tap or drag images</div>
        </div>

        <!-- Pods -->
        <div class="drop-zone" id="podZone">
          <input type="file" id="podFiles" accept="image/*" multiple />
          <div class="dz-icon">🟤</div>
          <div class="dz-label">Pods</div>
          <div class="dz-sub">Tap or drag images</div>
        </div>

        <!-- Seeds / Beans -->
        <div class="drop-zone" id="seedZone">
          <input type="file" id="seedFiles" accept="image/*" multiple />
          <div class="dz-icon">🫘</div>
          <div class="dz-label">Seeds / Beans</div>
          <div class="dz-sub">Tap or drag images</div>
        </div>

        <!-- Whole Plant -->
        <div class="drop-zone" id="plantZone">
          <input type="file" id="plantFiles" accept="image/*" multiple />
          <div class="dz-icon">🌱</div>
          <div class="dz-label">Whole Plant</div>
          <div class="dz-sub">Tap or drag images</div>
        </div>

      </div>

      <!-- Uploaded image thumbnails -->
      <div class="preview-strip" id="imagePreview"></div>
    </div>
  </div>

  <!-- ── ERROR MESSAGE ── -->
  <div class="error-box" id="errorBox"></div>

  <!-- ── SUBMIT BUTTON ── -->
  <button class="btn-analyse" id="analyseBtn" type="button">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <circle cx="11" cy="11" r="8"/>
      <line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    Analyse Cocoa Plant
  </button>

  <!-- ── RESULTS PANEL ── -->
  <div class="card" id="results">
    <div class="card-header" style="background: var(--green-leaf);">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
      </svg>
      Analysis Results
    </div>

    <!-- Loading animation -->
    <div class="loading-wrap" id="loadingWrap">
      <div class="cocoa-spinner"></div>
      <p id="loadingMsg">Analysing your cocoa plant…</p>
    </div>

    <!-- Results content (hidden until API response arrives) -->
    <div id="resultsContent" style="display:none">

      <!-- Ripeness gauge -->
      <div class="gauge-wrap">
        <div class="gauge-label" id="ripenessLabel">–</div>
        <div class="gauge-sub">Ripeness Status</div>
        <div class="gauge-bar-wrap">
          <div class="gauge-bar" id="gaugeBar"></div>
        </div>
        <div class="gauge-ticks">
          <span>Immature</span>
          <span>Developing</span>
          <span>Near-Ripe</span>
          <span>Ripe</span>
          <span>Over-Ripe</span>
        </div>
      </div>

      <hr class="divider" />

      <!-- Key metrics grid -->
      <div class="metrics-grid" id="metricsGrid"></div>

      <hr class="divider" />

      <!-- Observed characteristics -->
      <div class="narrative-section" id="characteristicsSection">
        <h3>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          Observed Characteristics
        </h3>
        <p id="characteristicsText"></p>
      </div>

      <hr class="divider" />

      <!-- Harvest recommendations -->
      <div class="narrative-section" id="harvestSection">
        <h3>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green-leaf)" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Harvest Recommendations
        </h3>
        <ul id="harvestList"></ul>
      </div>

      <hr class="divider" />

      <!-- Pest / disease risks -->
      <div class="narrative-section" id="riskSection">
        <h3>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--error)" stroke-width="2">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
          Potential Risks &amp; Advisories
        </h3>
        <ul id="riskList"></ul>
      </div>

      <hr class="divider" />

      <!-- Next steps -->
      <div class="narrative-section" id="nextSection">
        <h3>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brown-mid)" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"/>
            <polyline points="19 12 12 19 5 12"/>
          </svg>
          Suggested Next Steps
        </h3>
        <ul id="nextList"></ul>
      </div>

    </div><!-- /resultsContent -->
  </div><!-- /results card -->

  <!-- Disclaimer -->
  <p class="disclaimer">
    CocoaSense uses AI vision and language models. Results are advisory only and should be
    confirmed by an agronomist or extension officer. Not a substitute for professional agricultural advice.
  </p>

</main>

<!-- ════════════════════════════════════════════════
     APPLICATION SCRIPT
     Note: browsers do not execute .ts files directly.
     In production, compile app.ts → app.js with:
       npx tsc app.ts --target ES2020 --lib ES2020,DOM --outFile app.js
     Then reference <script src="app.js"></script> below.
     ════════════════════════════════════════════════ -->
<script src="app.js"></script>

</body>
</html>