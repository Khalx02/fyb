// ──────────────────────────────────────────────────
//  INTERFACES & TYPES
// ──────────────────────────────────────────────────
interface ImageEntry {
  file: File;
  dataUrl: string;
  category: string;
}

interface AnalysisResult {
  ripenessLabel: string;
  ripenessScore: number;
  weeksToHarvest: string;
  estimatedAgeWeeks: string;
  bestHarvestWindow: string;
  podYieldEstimate: string;
  characteristics: string;
  harvestRecommendations: string[];
  risks: string[];
  nextSteps: string[];
  gaugeColor: string;
}

interface AppState {
  images: ImageEntry[];
  audioBlob: Blob | null;
  audioName: string;
  recording: boolean;
  mediaRecorder: MediaRecorder | null;
  recChunks: BlobPart[];
  recSeconds: number;
  recInterval: ReturnType<typeof setInterval> | null;
}

// ──────────────────────────────────────────────────
//  APPLICATION STATE
// ──────────────────────────────────────────────────

const state: AppState = {
  images:        [],
  audioBlob:     null,
  audioName:     "",
  recording:     false,
  mediaRecorder: null,
  recChunks:     [],
  recSeconds:    0,
  recInterval:   null,
};

// ──────────────────────────────────────────────────
//  DOM REFERENCES
// ──────────────────────────────────────────────────

const textInput      = document.getElementById('textInput')      as HTMLTextAreaElement;
const recordBtn      = document.getElementById('recordBtn')      as HTMLButtonElement;
const recordLabel    = document.getElementById('recordLabel')    as HTMLSpanElement;
const recTimer       = document.getElementById('recTimer')       as HTMLSpanElement;
const audioStatus    = document.getElementById('audioStatus')    as HTMLDivElement;
const audioFile      = document.getElementById('audioFile')      as HTMLInputElement;
const analyseBtn     = document.getElementById('analyseBtn')     as HTMLButtonElement;
const errorBox       = document.getElementById('errorBox')       as HTMLDivElement;
const results        = document.getElementById('results')        as HTMLDivElement;
const loadingWrap    = document.getElementById('loadingWrap')    as HTMLDivElement;
const loadingMsg     = document.getElementById('loadingMsg')     as HTMLParagraphElement;
const resultsContent = document.getElementById('resultsContent') as HTMLDivElement;
const imagePreview   = document.getElementById('imagePreview')   as HTMLDivElement;

// ──────────────────────────────────────────────────
//  IMAGE HANDLING
// ──────────────────────────────────────────────────

/** Maps file-input IDs to human-readable category labels */
const imageCats: Record<string, string> = {
  leafFiles:  'leaf',
  podFiles:   'pod',
  seedFiles:  'seed/bean',
  plantFiles: 'whole plant',
};

/** Attach change listeners to all image file inputs */
(['leafFiles', 'podFiles', 'seedFiles', 'plantFiles'] as const).forEach(id => {
  const el = document.getElementById(id) as HTMLInputElement;
  el.addEventListener('change', () => handleImageFiles(el.files, imageCats[id]));
});

/** Attach drag-and-drop listeners to each drop zone */
const dropZoneCategories = ['leaf', 'pod', 'seed/bean', 'whole plant'];

(['leafZone', 'podZone', 'seedZone', 'plantZone'] as const).forEach((zoneId, i) => {
  const zone = document.getElementById(zoneId) as HTMLDivElement;

  zone.addEventListener('dragover', (e: DragEvent) => {
    e.preventDefault();
    zone.classList.add('drag-over');
  });

  zone.addEventListener('dragleave', () => {
    zone.classList.remove('drag-over');
  });

  zone.addEventListener('drop', (e: DragEvent) => {
    e.preventDefault();
    zone.classList.remove('drag-over');
    handleImageFiles(e.dataTransfer?.files ?? null, dropZoneCategories[i]);
  });
});

/**
 * Reads image files via FileReader, stores them in state,
 * and re-renders the preview strip.
 */
function handleImageFiles(files: FileList | null, category: string): void {
  if (!files) return;

  Array.from(files).forEach(file => {
    if (!file.type.startsWith('image/')) return;

    const reader = new FileReader();
    reader.onload = () => {
      state.images.push({ file, dataUrl: reader.result as string, category });
      renderPreviews();
    };
    reader.readAsDataURL(file);
  });
}

/** Renders thumbnail previews for all uploaded images */
function renderPreviews(): void {
  imagePreview.innerHTML = '';

  state.images.forEach((entry, idx) => {
    const wrap = document.createElement('div');
    wrap.className = 'preview-item';
    wrap.title = entry.category;

    const img = document.createElement('img');
    img.src = entry.dataUrl;
    img.alt = entry.category;

    const rm = document.createElement('button');
    rm.className = 'rm-btn';
    rm.innerHTML = '✕';
    rm.setAttribute('aria-label', `Remove ${entry.category} image`);
    rm.onclick = () => {
      state.images.splice(idx, 1);
      renderPreviews();
    };

    wrap.append(img, rm);
    imagePreview.appendChild(wrap);
  });
}

// ──────────────────────────────────────────────────
//  AUDIO RECORDING
// ──────────────────────────────────────────────────

recordBtn.addEventListener('click', async () => {
  if (!state.recording) {
    await startRecording();
  } else {
    stopRecording();
  }
});

/** Requests microphone access and starts MediaRecorder */
async function startRecording(): Promise<void> {
  try {
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });

    state.recChunks     = [];
    state.mediaRecorder = new MediaRecorder(stream);

    state.mediaRecorder.ondataavailable = (e: BlobEvent) => {
      state.recChunks.push(e.data);
    };

    state.mediaRecorder.onstop = () => {
      const blob = new Blob(state.recChunks, { type: 'audio/webm' });
      state.audioBlob = blob;
      state.audioName = `recording_${new Date().toISOString().slice(0, 19)}.webm`;
      showAudioStatus(`🎙 ${state.audioName}`);
      stream.getTracks().forEach(t => t.stop());
    };

    state.mediaRecorder.start();
    state.recording  = true;
    state.recSeconds = 0;

    recordBtn.classList.add('recording');
    recordLabel.textContent = 'Stop Recording';

    // Tick the timer every second
    state.recInterval = setInterval(() => {
      state.recSeconds++;
      const m = String(Math.floor(state.recSeconds / 60)).padStart(2, '0');
      const s = String(state.recSeconds % 60).padStart(2, '0');
      recTimer.textContent = `${m}:${s}`;
    }, 1000);

  } catch {
    showError('Microphone access denied. Please allow microphone permissions.');
  }
}

/** Stops an active MediaRecorder session */
function stopRecording(): void {
  state.mediaRecorder?.stop();
  state.recording = false;

  recordBtn.classList.remove('recording');
  recordLabel.textContent = 'Record Voice';
  recTimer.textContent    = '';

  if (state.recInterval) clearInterval(state.recInterval);
}

/** Handles uploading an existing audio file */
audioFile.addEventListener('change', () => {
  const file = audioFile.files?.[0];
  if (!file) return;
  state.audioBlob = file;
  state.audioName = file.name;
  showAudioStatus(`🎵 ${file.name}`);
});

/** Renders an audio status badge in the UI */
function showAudioStatus(msg: string): void {
  audioStatus.innerHTML = `<div class="audio-name">${msg}</div>`;
}

// ──────────────────────────────────────────────────
//  ANALYSIS — MAIN ENTRY POINT
// ──────────────────────────────────────────────────

analyseBtn.addEventListener('click', runAnalysis);

/** Validates inputs, calls the Claude API, and renders results */
async function runAnalysis(): Promise<void> {
  hideError();

  const text = textInput.value.trim();

  if (!text && state.images.length === 0 && !state.audioBlob) {
    showError('Please provide at least one input: a text description, voice recording, or image.');
    return;
  }

  // Show loading state
  analyseBtn.disabled          = true;
  results.style.display        = 'block';
  loadingWrap.style.display    = 'block';
  resultsContent.style.display = 'none';
  loadingMsg.textContent       = 'Analysing your cocoa plant…';
  results.scrollIntoView({ behavior: 'smooth', block: 'start' });

  // Cycle loading messages
  const loadingMessages = [
    'Reading plant indicators…',
    'Assessing pod colour and texture…',
    'Estimating development stage…',
    'Generating harvest forecast…',
  ];
  let msgIdx      = 0;
  const msgCycle  = setInterval(() => {
    msgIdx = (msgIdx + 1) % loadingMessages.length;
    loadingMsg.textContent = loadingMessages[msgIdx];
  }, 2800);

  try {
    const parsed = await callClaudeAPI(text);
    clearInterval(msgCycle);
    renderResults(parsed);
  } catch (err: unknown) {
    clearInterval(msgCycle);
    loadingWrap.style.display = 'none';
    results.style.display     = 'none';
    const msg = err instanceof Error ? err.message : 'An unexpected error occurred.';
    showError(`Analysis failed: ${msg}`);
  } finally {
    analyseBtn.disabled = false;
  }
}

// ──────────────────────────────────────────────────
//  CLAUDE API CALL
// ──────────────────────────────────────────────────

/** System prompt instructing Claude to behave as a cocoa agronomist */
const SYSTEM_PROMPT = `You are CocoaSense, an expert AI agricultural advisor specialising in Theobroma cacao (cocoa) cultivation. Your role is to analyse observations about cocoa plants — from text descriptions, voice notes, and images — and provide detailed, actionable analysis for farmers.

When analysing a submission, always return a valid JSON object (no markdown, no backticks) with EXACTLY this structure:
{
  "ripenessLabel": "string — e.g. 'Ripe', 'Near-Ripe', 'Developing', 'Immature', 'Over-Ripe'",
  "ripenessScore": number (0–100, where 0=immature, 50=near-ripe, 85=ripe, 100=over-ripe),
  "weeksToHarvest": "string — e.g. '0–1 week', '2–3 weeks', 'Already past peak'",
  "estimatedAgeWeeks": "string — e.g. '22–24 weeks since pod set'",
  "bestHarvestWindow": "string — e.g. 'Harvest within 5–7 days for maximum yield'",
  "podYieldEstimate": "string — e.g. 'Good pod fill expected; ~35–40 beans per pod'",
  "characteristics": "string — 2–4 sentences describing observed visual/physical traits and what they indicate",
  "harvestRecommendations": ["array of 3–5 specific actionable harvest tips as strings"],
  "risks": ["array of 2–4 potential pest/disease/environmental risks based on observations"],
  "nextSteps": ["array of 3–5 immediate action items for the farmer"],
  "gaugeColor": "string — a CSS hex colour matching the ripeness (green for ripe #4A7C3F, amber for near-ripe #C9812E, red for issues #C0392B, brown for immature #6B3A1F)"
}

Base your analysis on well-known cocoa ripeness indicators:
- Colour change from green → yellow/orange/red depending on variety
- Sound when tapped (hollow = ripe)
- Surface texture and firmness
- Leaf health as indicator of tree stress
- Visible mould, dark patches (Black Pod), insect damage (Capsid bugs, Pod borer)
- Season and regional context (West Africa, etc.)

Always be encouraging, practical, and use language accessible to smallholder farmers.`;

/**
 * Builds and sends a multimodal message to the Claude API.
 * Returns the parsed AnalysisResult JSON.
 */
async function callClaudeAPI(text: string): Promise<AnalysisResult> {
  // Note: Claude's API does not process audio directly.
  // We reference the audio by name and treat the farmer's text
  // as the transcription / combined observation.
  let audioNote = '';
  if (state.audioBlob) {
    audioNote = `\n[Farmer also submitted a voice recording: "${state.audioName}". Treat the text description as the transcription of this audio if no separate text is given.]`;
  }

  // Build the user message parts (text + optional images)
  const userParts: unknown[] = [
    {
      type: 'text',
      text: `Farmer's observation:\n${text || '(No text provided)'}${audioNote}\n\nPlease analyse the cocoa plant and return ONLY the JSON object described.`,
    },
  ];

  // Attach each image with its category label
  for (const img of state.images) {
    const base64    = img.dataUrl.split(',')[1];
    const mediaType = img.file.type || 'image/jpeg';

    userParts.push({
      type: 'text',
      text: `[Image category: ${img.category}]`,
    });

    userParts.push({
      type: 'image',
      source: {
        type:       'base64',
        media_type: mediaType,
        data:       base64,
      },
    });
  }

  const response = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model:      'claude-sonnet-4-6',
      max_tokens: 1000,
      system:     SYSTEM_PROMPT,
      messages:   [{ role: 'user', content: userParts }],
    }),
  });

  if (!response.ok) {
    const err = await response.json();
    throw new Error(err?.error?.message || `API error ${response.status}`);
  }

  const data    = await response.json();
  const rawText = (data.content as Array<{ type: string; text?: string }>)
    .filter(b => b.type === 'text')
    .map(b => b.text ?? '')
    .join('');

  // Strip any accidental markdown code fences before parsing
  const clean = rawText.replace(/```json|```/gi, '').trim();

  try {
    return JSON.parse(clean) as AnalysisResult;
  } catch {
    throw new Error('Could not parse AI response. Please try again.');
  }
}

// ──────────────────────────────────────────────────
//  RENDER RESULTS
// ──────────────────────────────────────────────────

/** Populates all result sections with data from the API */
function renderResults(d: AnalysisResult): void {
  loadingWrap.style.display    = 'none';
  resultsContent.style.display = 'block';

  // ── Ripeness gauge ──
  const score      = Math.max(0, Math.min(100, d.ripenessScore ?? 50));
  const gaugeColor = d.gaugeColor || '#4A7C3F';

  (document.getElementById('ripenessLabel') as HTMLElement).textContent = d.ripenessLabel || '—';

  const bar = document.getElementById('gaugeBar') as HTMLDivElement;
  bar.style.background = gaugeColor;
  // Slight delay allows CSS transition to animate from 0%
  setTimeout(() => { bar.style.width = `${score}%`; }, 80);

  // ── Key metrics ──
  const metricsGrid = document.getElementById('metricsGrid') as HTMLDivElement;
  metricsGrid.innerHTML = '';

  const metrics: Array<{ key: string; val: string; cls: string }> = [
    { key: 'Weeks to Harvest',   val: d.weeksToHarvest,    cls: ''      },
    { key: 'Estimated Pod Age',  val: d.estimatedAgeWeeks, cls: 'brown' },
    { key: 'Best Harvest Window',val: d.bestHarvestWindow, cls: 'green' },
    { key: 'Pod Yield Estimate', val: d.podYieldEstimate,  cls: ''      },
  ];

  metrics.forEach(m => {
    const pill = document.createElement('div');
    pill.className = `metric-pill ${m.cls}`;
    pill.innerHTML = `
      <div class="metric-val">${m.val || '—'}</div>
      <div class="metric-key">${m.key}</div>
    `;
    metricsGrid.appendChild(pill);
  });

  // ── Narrative sections ──
  (document.getElementById('characteristicsText') as HTMLElement)
    .textContent = d.characteristics || '—';

  renderList('harvestList', d.harvestRecommendations);
  renderList('riskList',    d.risks);
  renderList('nextList',    d.nextSteps);
}

/**
 * Renders an array of strings into a <ul> element.
 * Falls back to a placeholder message if the array is empty.
 */
function renderList(elementId: string, items: string[]): void {
  const el = document.getElementById(elementId) as HTMLUListElement;
  el.innerHTML = '';

  if (!Array.isArray(items) || items.length === 0) {
    el.innerHTML = '<li>No specific items identified.</li>';
    return;
  }

  items.forEach(item => {
    const li = document.createElement('li');
    li.textContent = item;
    el.appendChild(li);
  });
}

// ──────────────────────────────────────────────────
//  UTILITY FUNCTIONS
// ──────────────────────────────────────────────────

/** Displays an error message to the user */
function showError(msg: string): void {
  errorBox.textContent  = msg;
  errorBox.style.display = 'block';
  errorBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

/** Hides and clears the error box */
function hideError(): void {
  errorBox.style.display = 'none';
  errorBox.textContent   = '';
}
